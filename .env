# African Village Node Agent — Environment Configuration
# Copy to .env and fill in values before running

# ── Node identity ────────────────────────────────────────────────
NODE_ID=NODE-001
NODE_NAME=Russell Anchor
NODE_TYPE=anchor
ADDRESS=2317 West Chestnut Street
NEIGHBORHOOD=Russell
ANCHOR_SITE=Home Pilot

# ── Location (decimal degrees) ──────────────────────────────────
LATITUDE=38.2527
LONGITUDE=-85.7585

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://vctwodqmyrukatmpexkt.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Recommended: add service role key to bypass RLS for node writes
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── FCC license ──────────────────────────────────────────────────
FCC_DB_URL=https://geo.spectrumbridge.com/SpectrumBridge/api
FCC_QUERY_INTERVAL_MS=3600000

# ── Radio interfaces ─────────────────────────────────────────────
TVWS_INTERFACE=wlan0
MESH_INTERFACE=wlan1
MESH_IP=10.10.0.1
MESH_SSID=village-mesh
MESH_CHANNEL=2412

# ── Timers ───────────────────────────────────────────────────────
HEARTBEAT_INTERVAL_MS=60000
CACHE_SYNC_INTERVAL_MS=21600000

# ── Local paths ──────────────────────────────────────────────────
CACHE_DIR=/opt/village-node/cache
CACHE_MAX_GB=8

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=info

